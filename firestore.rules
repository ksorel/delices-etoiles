rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────
    function isAuth()    { return request.auth != null; }
    function isStaff()   { return isAuth() && request.auth.token.role in ['admin','manager','serveur','bar','cuisine','livreur','caissier','custom']; }
    function isAdmin()   { return isAuth() && request.auth.token.role == 'admin'; }
    function isOwner()   { return isAdmin(); }                                   // admin = propriétaire (global)
    function isManager() { return isAuth() && request.auth.token.role == 'manager'; }
    function isAnon()    { return isAuth() && request.auth.token.firebase.sign_in_provider == 'anonymous'; }
    function isCaissier() { return isAuth() && request.auth.token.role == 'caissier'; }
    function canEncaisser(){ return isAdmin() || isCaissier(); }

    // ─── Menu — catalogue PARTAGÉ entre établissements ─────────
    // Fiche article (nom, description, photo, catégorie) commune à tous les
    // lieux ; modifiable par le propriétaire OU n'importe quel gérant (pas de
    // restoId ici — le prix/la disponibilité par lieu vivent dans menu-dispo).
    match /menus/{itemId} {
      allow read:  if true;
      allow write: if isAdmin() || isManager();
    }

    // ─── Disponibilité/prix par établissement pour un article du catalogue ─
    match /menu-dispo/{dispoId} {
      allow read: if true;
      allow create: if isAdmin() || (isManager() && request.resource.data.restoId == request.auth.token.restoId);
      allow update, delete: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
    }

    // ─── Tables (lecture staff+, session anonyme OK) ───────────
    match /tables/{tableId} {
      allow read:   if isAuth();
      allow create: if isAnon();
      allow update: if isStaff() || isAnon();
    }

    // ─── Commandes ─────────────────────────────────────────────
    match /commandes/{orderId} {
      // Création : tout utilisateur authentifié (anonyme ou staff)
      allow create: if isAuth();

      // Lecture : staff ou tout user authentifié connaissant l'orderId
      // (l'orderId est un ID Firestore non-devinable = sécurité suffisante)
      allow read: if isAuth();

      // Mise à jour statut : staff seulement
      allow update: if isStaff();

      // Suppression : admin seulement
      allow delete: if isAdmin();
    }

    // ─── Réservations de table ───────────────────────────────
    match /reservations/{resaId} {
      allow create: if isAuth();     // client (anonyme) ou staff
      allow read:   if isAuth();
      allow update: if isStaff()     // confirmer / refuser
                    // Le client peut uniquement enregistrer son token de notification
                    // (FCM) sur sa propre réservation, rien d'autre (statut inclus).
                    || (isAuth() && resource.data.clientUid == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken']));
      allow delete: if isAdmin();
    }

    // ─── Zones de livraison (lecture publique, écriture admin + gérant scopé) ─
    match /zones-livraison/{zoneId} {
      allow read: if true;
      allow create: if isAdmin() || (isManager() && request.resource.data.restoId == request.auth.token.restoId);
      allow update, delete: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
    }

    // ─── Zones traiteur (Zone A — lecture publique, écriture admin) ─
    match /zones-traiteur/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Règles upselling (lecture publique, écriture admin + gérant scopé) ───
    match /upselling-rules/{ruleId} {
      allow read: if true;
      allow create: if isAdmin() || (isManager() && request.resource.data.restoId == request.auth.token.restoId);
      allow update, delete: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
    }

    // ─── Établissements (lecture publique : sélecteur client) ──
    // Lu AVANT l'auth anonyme (le sélecteur s'affiche avant bootApp),
    // donc lecture ouverte. Données non sensibles (nom, commune, adresse).
    // Créer/supprimer un établissement reste réservé au propriétaire (structure
    // globale du réseau) ; un gérant peut modifier la fiche de son propre lieu.
    match /restos/{restoId} {
      allow read:   if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isManager() && restoId == request.auth.token.restoId);
    }

    // ─── Staff / Admin (privé) ──────────────────────────────────
    match /staff/{uid} {
      allow read, write: if isAdmin() || request.auth.uid == uid;
    }

    // ─── Plat du jour (lecture publique, écriture admin + gérant scopé) ──────────
    match /plat-du-jour/{docId} {
      allow read: if true;
      allow create: if isAdmin() || (isManager() && request.resource.data.restoId == request.auth.token.restoId);
      allow update, delete: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
    }

    // ─── Plan de salle (écriture admin + gérant scopé à son établissement) ──
    match /floor-plan/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin() || (isManager() && request.resource.data.restoId == request.auth.token.restoId);
      allow update, delete: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
    }

    // ─── Sessions de table ──────────────────────────────────────
    match /sessions/{sessionId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isStaff() || (isAuth() && resource.data.clientUid == request.auth.uid);
    }

    // ─── Paiements ──────────────────────────────────────────────
    match /paiements/{paiementId} {
      allow read:   if isStaff();
      allow create: if isStaff() || canEncaisser();
      allow update: if isAdmin() || canEncaisser();
    }

    // ─── Stocks boissons (écriture admin + gérant scopé à son établissement) ──
    match /stocks/{itemId} {
      allow read:  if isAuth(); // Dashboard staff + admin
      allow create: if isAdmin() || (isManager() && request.resource.data.restoId == request.auth.token.restoId);
      allow update, delete: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
    }
    match /stock-movements/{id} {
      // Journal d'audit sans restoId (référence stockId, lui-même scopé) ;
      // la protection réelle est sur /stocks (écriture de quantité).
      allow read: if isStaff();
      allow create: if isAdmin() || isManager();
    }
    match /supplier-orders/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ─── Rapports (admin seulement) ────────────────────────────
    match /rapports/{rapportId} {
      allow read, write: if isAdmin();
    }

    // ─── Employés (lecture admin globale, ou gérant scopé à son établissement) ─
    match /employees/{uid} {
      // Lecture propre : un employé au rôle "personnalisé" doit pouvoir lire ses
      // propres permissions (employees/{uid}.customPermissions) au login.
      allow read:  if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId)
                   || request.auth.uid == uid;
      allow write: if false; // Géré par Cloud Functions uniquement (createEmployee, etc.)
    }

    // ─── Configuration restaurant ────────────────────────────
    match /config/{docId} {
      // Le carrousel d'accueil (doc 'accueil') est lu AVANT l'auth anonyme,
      // comme le sélecteur d'établissement → lecture publique. Contenu non
      // sensible (URLs d'images + booléen actif). Les autres docs config
      // (paiements, contacts du gérant) restent réservés aux utilisateurs authentifiés.
      // Un gérant peut modifier UNIQUEMENT le doc de son propre établissement
      // (docId == restoId) ; 'accueil' (carrousel global) reste propriétaire uniquement.
      allow read:  if docId == 'accueil' || isAuth();
      allow write: if isAdmin() || (isManager() && docId == request.auth.token.restoId);
    }

    // ─── Devis traiteur ──────────────────────────────────────
    match /devis/{devisId} {
      allow create: if isAuth();
      allow read:   if isAdmin()
                    || (isAuth() && resource.data.token != null); // Client avec lien sécurisé
      allow update: if isAdmin()
                    || (isAuth()  // Client peut confirmer/annuler/envoyer un message
                        && resource.data.token != null
                        && request.resource.data.token == resource.data.token); // token inchangé

      match /paiements/{pId} {
        allow read:   if isAdmin() || isAuth(); // client consulte ses propres paiements via token niveau parent
        allow create: if isAuth();              // client déclare un paiement
        allow update: if isAdmin();             // seul l'admin confirme la réception
      }
    }

    // ─── Prestations traiteur ────────────────────────────────
    match /prestations/{prestId} {
      allow read, write: if isAdmin();
    }

    // ─── Notifications (alertes traiteur J-1/J-7) ────────────
    match /notifications/{notifId} {
      allow read, update: if isAuth(); // dashboard staff peut lire et marquer lu
      allow write:        if isAdmin();
    }

    // ─── Comptabilité — Dépenses (admin + gérant scopé à son établissement) ───
    match /depenses/{depId} {
      allow read: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
      allow create: if isAdmin() || (isManager() && request.resource.data.restoId == request.auth.token.restoId);
      allow update, delete: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
    }

    // ─── Avis clients sur les articles (par établissement) ─────
    // ID déterministe {restoId}_{menuId}_{uid} : 1 avis max par client/plat/lieu.
    // L'achat vérifié (le client a bien commandé ce plat) est contrôlé côté client ;
    // ici on ne garantit que la forme des données et l'unicité par uid.
    match /avis/{avisId} {
      allow read: if true;
      allow create: if isAuth()
                    && avisId == (request.resource.data.restoId + '_' + request.resource.data.menuId + '_' + request.auth.uid)
                    && request.resource.data.clientUid == request.auth.uid
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
                    && request.resource.data.comment.size() <= 300
                    && request.resource.data.status == 'visible';
      allow update: if false; // immuable une fois publié
      allow delete: if isAdmin() || (isManager() && resource.data.restoId == request.auth.token.restoId);
    }
  }
}
