rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────
    function isAuth()    { return request.auth != null; }
    function isStaff()   { return isAuth() && request.auth.token.role in ['admin','manager','serveur','bar','cuisine','livreur','caissier']; }
    function isAdmin()   { return isAuth() && request.auth.token.role == 'admin'; }
    function isOwner()   { return isAdmin(); }                                   // admin = propriétaire (global)
    function isManager() { return isAuth() && request.auth.token.role == 'manager'; }
    function isAnon()    { return isAuth() && request.auth.token.firebase.sign_in_provider == 'anonymous'; }
    function isCaissier() { return isAuth() && request.auth.token.role == 'caissier'; }
    function canEncaisser(){ return isAdmin() || isCaissier(); }

    // ─── Menu (lecture publique, écriture admin) ───────────────
    match /menus/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Tables (lecture staff+, session anonyme OK) ───────────
    match /tables/{tableId} {
      allow read:   if isAuth();
      allow create: if isAnon();
      allow update: if isStaff() || isAnon();
    }

    // ─── Commandes ─────────────────────────────────────────────
    match /commandes/{orderId} {
      // Création : tout utilisateur authentifié (anonyme ou staff)
      allow create: if isAuth();

      // Lecture : staff ou tout user authentifié connaissant l'orderId
      // (l'orderId est un ID Firestore non-devinable = sécurité suffisante)
      allow read: if isAuth();

      // Mise à jour statut : staff seulement
      allow update: if isStaff();

      // Suppression : admin seulement
      allow delete: if isAdmin();
    }

    // ─── Réservations de table ───────────────────────────────
    match /reservations/{resaId} {
      allow create: if isAuth();     // client (anonyme) ou staff
      allow read:   if isAuth();
      allow update: if isStaff();    // confirmer / refuser
      allow delete: if isAdmin();
    }

    // ─── Zones de livraison (lecture publique, écriture admin) ─
    match /zones-livraison/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Zones traiteur (Zone A — lecture publique, écriture admin) ─
    match /zones-traiteur/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Règles upselling (lecture publique, écriture admin) ───
    match /upselling-rules/{ruleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Établissements (lecture publique : sélecteur client) ──
    // Lu AVANT l'auth anonyme (le sélecteur s'affiche avant bootApp),
    // donc lecture ouverte. Données non sensibles (nom, commune, adresse).
    match /restos/{restoId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Staff / Admin (privé) ──────────────────────────────────
    match /staff/{uid} {
      allow read, write: if isAdmin() || request.auth.uid == uid;
    }

    // ─── Plat du jour (lecture publique, écriture admin) ──────────
    match /plat-du-jour/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Plan de salle ──────────────────────────────────────
    match /floor-plan/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Sessions de table ──────────────────────────────────────
    match /sessions/{sessionId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isStaff() || (isAuth() && resource.data.clientUid == request.auth.uid);
    }

    // ─── Paiements ──────────────────────────────────────────────
    match /paiements/{paiementId} {
      allow read:   if isStaff();
      allow create: if isStaff() || canEncaisser();
      allow update: if isAdmin() || canEncaisser();
    }

    // ─── Stocks boissons ────────────────────────────────────────
    match /stocks/{itemId} {
      allow read:  if isAuth(); // Dashboard staff + admin
      allow write: if isAdmin();
    }
    match /stock-movements/{id} {
      allow read: if isStaff();
      allow create: if isAdmin();
    }
    match /supplier-orders/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ─── Rapports (admin seulement) ────────────────────────────
    match /rapports/{rapportId} {
      allow read, write: if isAdmin();
    }

    // ─── Employés ────────────────────────────────────────────
    match /employees/{uid} {
      allow read:  if isAdmin();
      allow write: if false; // Géré par Cloud Functions uniquement
    }

    // ─── Configuration restaurant ────────────────────────────
    match /config/{docId} {
      // Le carrousel d'accueil (doc 'accueil') est lu AVANT l'auth anonyme,
      // comme le sélecteur d'établissement → lecture publique. Contenu non
      // sensible (URLs d'images + booléen actif). Les autres docs config
      // (paiements, contacts du gérant) restent réservés aux utilisateurs authentifiés.
      allow read:  if docId == 'accueil' || isAuth();
      allow write: if isAdmin();
    }

    // ─── Devis traiteur ──────────────────────────────────────
    match /devis/{devisId} {
      allow create: if isAuth();
      allow read:   if isAdmin()
                    || (isAuth() && resource.data.token != null); // Client avec lien sécurisé
      allow update: if isAdmin()
                    || (isAuth()  // Client peut confirmer/annuler/envoyer un message
                        && resource.data.token != null
                        && request.resource.data.token == resource.data.token); // token inchangé

      match /paiements/{pId} {
        allow read:   if isAdmin() || isAuth(); // client consulte ses propres paiements via token niveau parent
        allow create: if isAuth();              // client déclare un paiement
        allow update: if isAdmin();             // seul l'admin confirme la réception
      }
    }

    // ─── Prestations traiteur ────────────────────────────────
    match /prestations/{prestId} {
      allow read, write: if isAdmin();
    }

    // ─── Notifications (alertes traiteur J-1/J-7) ────────────
    match /notifications/{notifId} {
      allow read, update: if isAuth(); // dashboard staff peut lire et marquer lu
      allow write:        if isAdmin();
    }

    // ─── Comptabilité — Dépenses (admin uniquement) ───────────
    match /depenses/{depId} {
      allow read, write: if isAdmin();
    }
  }
}
