rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Photos des plats ────────────────────────────────────
    match /plats/{imageId} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin';
    }

    // ─── Images boissons et menus ────────────────────────────
    match /boissons/{imageId} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin';
    }
    match /menus/{imageId} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin';
    }

    // ─── Documents devis traiteur ────────────────────────────
    match /devis/{fileName} {
      allow read:  if request.auth != null
                   && request.auth.token.role == 'admin';
      allow create: if request.auth != null;
    }

    // ─── Justificatifs de dépenses (comptabilité) ─────────────
    match /depenses/{fileName} {
      allow read:  if request.auth != null && request.auth.token.role == 'admin';
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // ─── Carrousel d'accueil (images publiques, écriture propriétaire) ─
    match /accueil/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin';
    }

    // ─── Logos d'établissement (images publiques, écriture propriétaire) ─
    match /restos/{restoId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin';
    }

    // ─── Fallback ────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
