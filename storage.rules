rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Photos des plats ────────────────────────────────────
    match /plats/{imageId} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin';
    }

    // ─── Documents devis traiteur ────────────────────────────
    // Tout utilisateur authentifié (y compris anonyme) peut uploader
    match /devis/{fileName} {
      allow read:  if request.auth != null
                   && request.auth.token.role == 'admin';
      allow create: if request.auth != null
                    && request.resource.size < 5 * 1024 * 1024;
    }

    // ─── Fallback ────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
